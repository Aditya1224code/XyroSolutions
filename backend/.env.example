# MongoDB Atlas Connection
# Replace with your MongoDB connection string
MONGODB_URI=YOUR_MONGODB_CONNECTION_STRING

# JWT Configuration
JWT_SECRET=YOUR_JWT_SECRET
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email Configuration
# If BREVO_API_KEY is set, the app uses Brevo API and does not need EMAIL_USER/EMAIL_PASS.
# If BREVO_API_KEY is not set, the app falls back to SMTP and uses EMAIL_HOST/EMAIL_PORT/EMAIL_USER/EMAIL_PASS.
EMAIL_PROVIDER=auto
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM="Your Name <no-reply@yourdomain.com>"

# SMTP fallback (only needed if not using Brevo API)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASS=YOUR_EMAIL_APP_PASSWORD
EMAIL_FROM="Your Name <your-email@example.com>"

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_in_production

# Cloudinary Configuration (for image/video hosting)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret